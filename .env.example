# Percorso del file JSON della service account Firebase (relativo alla root del backend).
# Il file NON va committato (è in .gitignore).
FIREBASE_CREDENTIALS_PATH=

# Firebase (client SDK usato dal backend per getAuth)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# URL del frontend (CORS + redirect Stripe). Senza slash finale.
FRONTEND_URL=https://habit-money-front.vercel.app

# Porta del server (default 3000)
PORT=3000

# Stripe (Premium una-tantum)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Secret condiviso per l'endpoint di invio reminder (cron). Vedi notifiche.
CRON_SECRET=
